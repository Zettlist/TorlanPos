# Google App Engine Configuration
# This file configures the Node.js runtime for the backend

runtime: nodejs20

env: standard

instance_class: F2

automatic_scaling:
  min_instances: 1
  max_instances: 10
  target_cpu_utilization: 0.65

handlers:
  - url: /.*
    script: auto
    secure: always

env_variables:
  NODE_ENV: "production"
  TZ: "America/Mexico_City"
  DB_HOST: "/cloudsql/YOUR_PROJECT_ID:REGION:INSTANCE_NAME"
  DB_USER: "YOUR_DB_USER"
  DB_NAME: "YOUR_DB_NAME"
  DB_PORT: "3306"
  DB_PASSWORD: "YOUR_DB_PASSWORD"
  JWT_SECRET: "YOUR_JWT_SECRET"

# Database connection using Cloud SQL
beta_settings:
  cloud_sql_instances: YOUR_PROJECT_ID:REGION:INSTANCE_NAME
