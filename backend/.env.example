# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Configuration (Google Cloud SQL)
DB_HOST=your-cloud-sql-connection-name
DB_USER=your-database-user
DB_PASSWORD=your-secure-password
DB_NAME=torlan_pos

# JWT Secret (CRITICAL: Use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=8080
NODE_ENV=production
TZ=America/Mexico_City

# External Integrations
EXTERNAL_API_KEY=your_secret_api_key_here

# Bisonte Shop Integration (para captura de pagos web)
BISONTE_SHOP_URL=https://your-bisonte-shop-domain.com
BISONTE_CAPTURE_KEY=your_bisonte_capture_key
